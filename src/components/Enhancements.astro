---
// Lightweight, framework-free islands shared across all pages:
//  • image lightbox  — click any image inside a `.lightbox-scope`
//  • scroll reveal    — elements with [data-reveal] fade/slide in once
// Re-initialised on `astro:page-load` so they keep working across view transitions.
---
<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/92 p-4 backdrop-blur-sm md:p-10"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <button
    id="lightbox-close"
    class="label absolute right-4 top-4 z-10 flex items-center gap-2 px-2 py-1 text-ink-muted transition-colors hover:text-ink md:right-8 md:top-6"
    aria-label="Close image viewer"
  >
    Close <span aria-hidden="true" class="text-base leading-none">×</span>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-h-full max-w-full object-contain" />
</div>

<script>
  function pickLargest(img: HTMLImageElement): string {
    // Prefer the highest-resolution candidate from any srcset.
    if (img.currentSrc) return img.currentSrc;
    if (img.srcset) {
      const best = img.srcset
        .split(',')
        .map((s) => s.trim().split(/\s+/))
        .sort((a, b) => parseInt(b[1] || '0') - parseInt(a[1] || '0'))[0];
      if (best) return best[0];
    }
    return img.src;
  }

  function initLightbox() {
    const box = document.getElementById('lightbox');
    const boxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const closeBtn = document.getElementById('lightbox-close');
    if (!box || !boxImg) return;

    const open = (img: HTMLImageElement) => {
      boxImg.src = pickLargest(img);
      boxImg.alt = img.alt || '';
      box.classList.remove('hidden');
      box.classList.add('flex');
      box.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';
    };
    const close = () => {
      box.classList.add('hidden');
      box.classList.remove('flex');
      box.setAttribute('aria-hidden', 'true');
      boxImg.src = '';
      document.documentElement.style.overflow = '';
    };

    // Delegated: any image inside a lightbox scope.
    document.querySelectorAll<HTMLElement>('.lightbox-scope').forEach((scope) => {
      scope.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        if (t.tagName === 'IMG') open(t as HTMLImageElement);
      });
    });
    closeBtn?.addEventListener('click', close);
    box.addEventListener('click', (e) => {
      if (e.target === box) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !box.classList.contains('hidden')) close();
    });
  }

  function initReveal() {
    const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
    if (!('IntersectionObserver' in window) || !els.length) return;
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        }
      },
      { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
    );
    els.forEach((el) => io.observe(el));
  }

  function init() {
    initLightbox();
    initReveal();
  }

  document.addEventListener('astro:page-load', init);
  // First load (in case the event already fired)
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>

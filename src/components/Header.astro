---
import { SITE, NAV } from '@/consts';
import { withBase } from '@/lib/url';

const path = Astro.url.pathname.replace(/\/$/, '');
const isActive = (href: string) => {
  const target = withBase(href).replace(/\/$/, '');
  return path === target || (href !== '/' && path.startsWith(target));
};
---
<header class="sticky top-0 z-50 border-b border-line bg-bg/80 backdrop-blur-md">
  <div class="container-page flex h-14 items-center justify-between md:h-16">
    <a href={withBase('/')} class="group flex items-center gap-2.5" aria-label={`${SITE.title} — home`}>
      <span
        class="inline-block h-3.5 w-3.5 bg-accent transition-transform duration-300 ease-[var(--ease-out-expo)] group-hover:rotate-90"
        aria-hidden="true"
      ></span>
      <span class="font-display text-[0.95rem] font-semibold tracking-tight">{SITE.title}</span>
    </a>
    <nav class="flex items-center gap-5 md:gap-8" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={withBase(item.href)}
            class:list={[
              'label link-underline !text-[0.7rem]',
              isActive(item.href) ? '!text-ink' : 'hover:!text-ink',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

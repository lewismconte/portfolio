---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import CategoryFilter from '@/components/CategoryFilter.astro';
import { CATEGORIES } from '@/consts';

const projects = (
  await getCollection('projects', ({ data }) => import.meta.env.PROD ? !data.draft : true)
).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

const available = CATEGORIES.filter((c) => projects.some((p) => p.data.category === c));
---
<BaseLayout title="Work" description="Selected architecture, computational design and BIM-tooling projects by Lewis Conte.">
  <section class="container-page pt-12 md:pt-20">
    <p class="label">Selected Work</p>
    <h1 class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight md:text-6xl">
      Buildings, tools and experiments.
    </h1>
    <p class="mt-5 max-w-xl text-ink-muted">
      {projects.length} projects spanning built work, computational design, BIM tooling and creative practice.
      Filter by discipline.
    </p>
  </section>

  <section class="container-page mt-10 md:mt-14">
    <CategoryFilter available={available} />

    <div
      id="project-grid"
      class="mt-10 grid grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2 lg:grid-cols-3"
    >
      {projects.map((entry, i) => <ProjectCard entry={entry} eager={i < 3} />)}
    </div>

    <p id="filter-empty" hidden class="py-16 text-center text-ink-muted">
      Nothing in this category yet.
    </p>
  </section>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import LabCard from '@/components/LabCard.astro';

const experiments = (
  await getCollection('lab', ({ data }) => import.meta.env.PROD ? !data.draft : true)
).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});
---
<BaseLayout title="Lab" description="Interactive geometry generators and computational experiments by Lewis Conte.">
  <section class="container-page pt-12 md:pt-20">
    <p class="label">Lab</p>
    <h1 class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight md:text-6xl">
      Generators & experiments.
    </h1>
    <p class="mt-5 max-w-xl text-ink-muted">
      Small, self-contained tools and sketches — geometry generators, parametric toys and the odd
      thing that didn't fit anywhere else. Each one runs live in your browser.
    </p>
  </section>

  <section class="container-page mt-10 border-t border-line pt-10 md:mt-14">
    {experiments.length === 0 ? (
      <p class="py-16 text-ink-muted">Nothing here yet — soon.</p>
    ) : (
      <div class="grid grid-cols-1 gap-x-6 gap-y-12 sm:grid-cols-2">
        {experiments.map((entry) => <LabCard entry={entry} />)}
      </div>
    )}
  </section>
</BaseLayout>

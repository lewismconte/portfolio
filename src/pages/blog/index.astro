---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import { withBase } from '@/lib/url';

const posts = (
  await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Notebook" description="Writing on architecture, computational design and BIM tooling by Lewis Conte.">
  <section class="container-page pt-12 md:pt-20">
    <p class="label">Notebook</p>
    <h1 class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight md:text-6xl">
      Notes on design & technology.
    </h1>
    <p class="mt-5 max-w-xl text-ink-muted">
      Short, frequent writing on computational design, the tools I build, and what I'm looking at.
    </p>
  </section>

  <section class="container-page mt-12 border-t border-line md:mt-16">
    {posts.length === 0 && <p class="py-16 text-ink-muted">No posts yet — soon.</p>}
    <ul>
      {
        posts.map((post) => (
          <li class="border-b border-line" data-reveal>
            <a href={withBase(`/blog/${post.id}`)} class="group grid gap-2 py-7 md:grid-cols-12 md:gap-6">
              <div class="md:col-span-3">
                <span class="label"><FormattedDate date={post.data.date} /></span>
              </div>
              <div class="md:col-span-9">
                <h2 class="text-2xl font-semibold tracking-tight transition-colors group-hover:text-accent md:text-3xl">
                  {post.data.title}
                </h2>
                <p class="mt-2 max-w-2xl text-ink-muted">{post.data.summary}</p>
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((t) => (
                      <span class="label !text-ink-faint">#{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
